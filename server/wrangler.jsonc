{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "prodo-api-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-17",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "api.prodo.live",
			"custom_domain": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "prodo-db",
			"database_id": "38036841-460b-4ecf-8048-f2eeeae4db16"
		}
	]
}
